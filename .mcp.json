{
  "mcpServers": {
    "filigree": {
      "headers": {
        "Authorization": "Bearer ${WEFT_FEDERATION_TOKEN}"
      },
      "type": "streamable-http",
      "url": "http://localhost:8749/mcp/?project=lacuna"
    },
    "legis": {
      "args": [
        "mcp",
        "--agent-id",
        "claude-code"
      ],
      "command": "/home/john/.local/bin/legis",
      "env": {},
      "type": "stdio"
    },
    "loomweave": {
      "args": [
        "serve"
      ],
      "command": "/home/john/.local/share/uv/tools/loomweave/bin/loomweave",
      "env": {},
      "type": "stdio"
    },
    "wardline": {
      "args": [
        "mcp",
        "--root",
        ".",
        "--loomweave-url",
        "http://127.0.0.1:9730",
        "--filigree-url",
        "http://127.0.0.1:8749/api/p/lacuna/weft/scan-results"
      ],
      "command": "/home/john/.local/bin/wardline",
      "type": "stdio"
    }
  }
}
