{
  "mcpServers": {
    "filigree": {
      "headers": {
        "Authorization": "Bearer ${FILIGREE_API_TOKEN}"
      },
      "type": "streamable-http",
      "url": "http://localhost:8749/mcp/?project=lacuna"
    },
    "loomweave": {
      "args": [
        "serve"
      ],
      "command": "/home/john/.local/share/uv/tools/loomweave/bin/loomweave",
      "env": {},
      "type": "stdio"
    },
    "wardline": {
      "args": [
        "mcp",
        "--root",
        ".",
        "--loomweave-url",
        "http://127.0.0.1:9730",
        "--filigree-url",
        "http://127.0.0.1:8749/api/weft/scan-results"
      ],
      "command": "/home/john/.local/bin/wardline",
      "type": "stdio"
    }
  }
}
